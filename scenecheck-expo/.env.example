# Copy this file to .env and fill in real values from your Supabase project
# dashboard (https://app.supabase.com → Project Settings → API).
#
# The EXPO_PUBLIC_ prefix is required — only prefixed vars are inlined into
# the client bundle by Expo. Vars without it stay server-only.
#
# Use the PUBLISHABLE key (string starting with `sb_publishable_`) — that's
# Supabase's current recommended client-side key. The legacy anon JWT
# (`eyJ...`) still works as a fallback; see lib/supabase.ts. NEVER put the
# secret / service_role key here — it bypasses RLS and would be visible in
# the shipped bundle.
#
# After editing .env, restart with `npx expo start --clear` once. Env vars
# are read at bundle time, not runtime, so subsequent edits also need a
# restart (without --clear).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Backward-compatible fallback. Only set this if you're using the legacy
# anon JWT (e.g. a project created before the new key system). The
# PUBLISHABLE_KEY var above takes precedence when both are set.
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Force mock-mode regardless of whether Supabase keys are set. Useful for
# demos or running tests without a live backend.
# EXPO_PUBLIC_USE_MOCK=1
