# Copy this file to .env (which is gitignored) and fill in real values from
# your Supabase project dashboard. The values below are placeholders.
#
# These are read by the frontend when running against the live backend
# (window.scFixes.liveBackend = true). The anon key is safe to ship in client
# code, but should still come from env vars to avoid baking it into source.

SC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
